                                                <DiscreteDoubleKeyFrame KeyTime="0:0:1.76" Value="0"/>
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:1.86" Value="-0.8"/>
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:1.96" Value="0.6"/>
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:2.10" Value="0"/>
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:3.40" Value="0"/>
