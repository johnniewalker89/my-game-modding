                                            <DoubleAnimation Storyboard.TargetName="NavSignalStripeGhost" Storyboard.TargetProperty="Opacity" From="0" To="0.42" Duration="0:0:0.26" BeginTime="0:0:1.96" AutoReverse="True"/>
