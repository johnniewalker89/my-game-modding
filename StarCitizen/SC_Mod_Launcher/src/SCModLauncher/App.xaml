                                            <DoubleAnimation Storyboard.TargetName="NavTearWideCyan" Storyboard.TargetProperty="Opacity" From="0" To="0.22" Duration="0:0:0.30" BeginTime="0:0:1.86" AutoReverse="True"/>
                                            <DoubleAnimation Storyboard.TargetName="NavTearWideAmber" Storyboard.TargetProperty="Opacity" From="0" To="0.14" Duration="0:0:0.28" BeginTime="0:0:2.06" AutoReverse="True"/>
                                            <DoubleAnimation Storyboard.TargetName="NavTearWideWhite" Storyboard.TargetProperty="Opacity" From="0" To="0.12" Duration="0:0:0.32" BeginTime="0:0:2.28" AutoReverse="True"/>
                                            <DoubleAnimation Storyboard.TargetName="NavTearTopBorderCyan" Storyboard.TargetProperty="Opacity" From="0" To="0.28" Duration="0:0:0.28" BeginTime="0:0:1.74" AutoReverse="True"/>
                                            <DoubleAnimation Storyboard.TargetName="NavTearRightBorderAmber" Storyboard.TargetProperty="Opacity" From="0" To="0.18" Duration="0:0:0.26" BeginTime="0:0:2.02" AutoReverse="True"/>
                                            <DoubleAnimation Storyboard.TargetName="NavTearBottomBorderCyan" Storyboard.TargetProperty="Opacity" From="0" To="0.22" Duration="0:0:0.28" BeginTime="0:0:2.34" AutoReverse="True"/>
                                            <DoubleAnimation Storyboard.TargetName="NavCyanTextGhost" Storyboard.TargetProperty="Opacity" From="0" To="0.22" Duration="0:0:0.32" BeginTime="0:0:1.92" AutoReverse="True"/>
                                            <DoubleAnimation Storyboard.TargetName="NavAmberTextGhost" Storyboard.TargetProperty="Opacity" From="0" To="0.14" Duration="0:0:0.28" BeginTime="0:0:2.04" AutoReverse="True"/>
