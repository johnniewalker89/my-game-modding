                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="Active">
                                <Setter TargetName="NavBody" Property="Fill" Value="#B8152D36"/>
                                <Setter TargetName="NavBody" Property="Stroke" Value="#5A66E8FF"/>
                                <Setter TargetName="NavWarpFrame" Property="Opacity" Value="0.52"/>
                                <Setter TargetName="NavPlateGhosts" Property="Opacity" Value="0.16"/>
                                <Setter TargetName="NavScanlines" Property="Opacity" Value="0.18"/>
                                <Setter TargetName="NavTearLayer" Property="Opacity" Value="0.20"/>
                                <Setter Property="Foreground" Value="{StaticResource SignalCyan}"/>
                            </DataTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.78"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42"/>
                            </Trigger>
