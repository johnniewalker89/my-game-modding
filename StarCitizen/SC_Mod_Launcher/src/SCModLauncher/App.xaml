                                <Rectangle x:Name="PathFrameAmberRip" Height="2" Width="38" Fill="{StaticResource SignalAmber}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-10,11" Opacity="0"/>
