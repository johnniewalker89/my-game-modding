                                                <DiscreteThicknessKeyFrame KeyTime="0:0:2.22" Value="0,0,1,0"/>
                                                <DiscreteThicknessKeyFrame KeyTime="0:0:2.46" Value="0,0,0,0"/>
                                                <DiscreteThicknessKeyFrame KeyTime="0:0:3.40" Value="0,0,0,0"/>
                                            </ThicknessAnimationUsingKeyFrames>
                                            <ThicknessAnimationUsingKeyFrames Storyboard.TargetName="NavFrameBottomB" Storyboard.TargetProperty="Margin">
                                                <DiscreteThicknessKeyFrame KeyTime="0:0:0.00" Value="0,0,0,0"/>
                                                <DiscreteThicknessKeyFrame KeyTime="0:0:2.04" Value="0,0,-4,-1"/>
                                                <DiscreteThicknessKeyFrame KeyTime="0:0:2.30" Value="0,0,1,0"/>
                                                <DiscreteThicknessKeyFrame KeyTime="0:0:2.52" Value="0,0,0,0"/>
                                                <DiscreteThicknessKeyFrame KeyTime="0:0:3.40" Value="0,0,0,0"/>
