                                <Setter TargetName="NavBody" Property="Fill" Value="#B8152D36"/>
                                <Setter TargetName="NavBody" Property="Stroke" Value="#5A66E8FF"/>
                                <Setter TargetName="NavWarpFrame" Property="Opacity" Value="0.52"/>
                                <Setter TargetName="NavPlateGhosts" Property="Opacity" Value="0.16"/>
                                <Setter TargetName="NavScanlines" Property="Opacity" Value="0.18"/>
