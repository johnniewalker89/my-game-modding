                    <WrapPanel Grid.Row="1" VerticalAlignment="Center">
                        <Button x:Name="OverviewNavButton" AutomationProperties.AutomationId="OverviewNavButton" Style="{StaticResource NavButton}" Click="ShowOverview"/>
                        <Button x:Name="ModulesNavButton" AutomationProperties.AutomationId="ModulesNavButton" Style="{StaticResource NavButton}" Click="ShowModules"/>
                        <Button x:Name="LocalizationNavButton" AutomationProperties.AutomationId="LocalizationNavButton" Style="{StaticResource NavButton}" Click="ShowLocalization"/>
                        <Button x:Name="RestoreBackupButton" AutomationProperties.AutomationId="RestoreBackupButton" Style="{StaticResource NavButton}" Click="ShowBackup"/>
