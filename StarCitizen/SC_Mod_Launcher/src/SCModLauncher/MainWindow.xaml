                        <Button x:Name="WarmCacheButton" AutomationProperties.AutomationId="WarmCacheButton" Style="{StaticResource LaunchCommandButton}" MinHeight="42" Margin="0,0,8,0" Click="WarmCache"/>
                        <Button x:Name="ApplyLiveButton" AutomationProperties.AutomationId="ApplyLiveButton" Style="{StaticResource LaunchCommandButton}" MinHeight="42" Click="RunLiveApply"/>
