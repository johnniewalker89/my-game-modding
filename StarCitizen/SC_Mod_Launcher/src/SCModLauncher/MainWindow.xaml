                Height="18"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0"
                Background="Transparent"
                Cursor="SizeNESW"
                MouseLeftButtonDown="TopRightResizeGripMouseLeftButtonDown"
                Panel.ZIndex="100">
            <ResizeGrip Width="18"
                        Height="18"
                        IsHitTestVisible="False"
                        Opacity="0.9"
                        RenderTransformOrigin="0.5,0.5">
                <ResizeGrip.RenderTransform>
                    <RotateTransform Angle="-90"/>
                </ResizeGrip.RenderTransform>
            </ResizeGrip>
        </Border>
    </Grid>
</Window>
