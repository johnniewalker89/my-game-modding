<Window x:Class="SCModLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="SC Mod Launcher"
        AutomationProperties.AutomationId="RootWindow"
        Width="1280"
        Height="820"
        MinWidth="1120"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource HullBlack}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Image x:Name="BackdropImage" Stretch="UniformToFill" Opacity="0.84"/>
        <Rectangle Fill="#5C070B0F"/>
        <Rectangle>
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.72,0.34" GradientOrigin="0.72,0.34" RadiusX="0.86" RadiusY="0.92">
                    <GradientStop Color="#16288999" Offset="0"/>
                    <GradientStop Color="#38070B0F" Offset="0.48"/>
                    <GradientStop Color="#8E070B0F" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Border Background="{StaticResource GlassPanel}" IsHitTestVisible="False"/>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="104"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="132"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PanelBorder}" Padding="16" Margin="0" MouseLeftButtonDown="HeaderMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Height="66" Margin="0,-4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Width="144" Height="66" ClipToBounds="False" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <TranslateTransform x:Name="LogoJitter" X="0" Y="0"/>
                                </Grid.RenderTransform>
                                <Grid.Effect>
                                    <DropShadowEffect x:Name="LogoGlow"
                                                      BlurRadius="7"
                                                      ShadowDepth="0"
                                                      Opacity="0.30"
                                                      Color="#66E8FF"/>
                                </Grid.Effect>
                                <Grid.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="LogoJitter"
                                                                     Storyboard.TargetProperty="X"
                                                                     From="-0.28"
                                                                     To="0.28"
                                                                     Duration="0:0:0.48"
                                                                     AutoReverse="True"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoGlow"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     From="0.16"
                                                                     To="0.40"
                                                                     Duration="0:0:1.22"
                                                                     AutoReverse="True"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0.90"
                                                                     To="1"
                                                                     Duration="0:0:1.38"
                                                                     AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Grid.Triggers>
                                <Canvas>
                                    <TextBlock Text="S" Canvas.Left="0" Canvas.Top="-6" Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI Black" FontSize="52" FontWeight="Black"/>
                                    <TextBlock Text="C" Canvas.Left="41" Canvas.Top="-6" Foreground="{StaticResource SignalCyan}" FontFamily="Segoe UI Black" FontSize="52" FontWeight="Black"/>
                                    <TextBlock Text="M" Canvas.Left="84" Canvas.Top="-6" Foreground="{StaticResource SignalAmber}" FontFamily="Segoe UI Black" FontSize="52" FontWeight="Black"/>
                                </Canvas>
                                <Canvas IsHitTestVisible="False">
                                    <Rectangle Width="18" Height="3" Canvas.Left="4" Canvas.Top="8" Fill="{StaticResource HullBlack}" Opacity="0.74"/>
                                    <Rectangle Width="25" Height="2" Canvas.Left="14" Canvas.Top="29" Fill="{StaticResource HullBlack}" Opacity="0.58"/>
                                    <Rectangle Width="18" Height="2" Canvas.Left="4" Canvas.Top="50" Fill="{StaticResource HullBlack}" Opacity="0.54"/>
                                    <Rectangle Width="22" Height="3" Canvas.Left="43" Canvas.Top="12" Fill="{StaticResource HullBlack}" Opacity="0.70"/>
                                    <Rectangle Width="16" Height="2" Canvas.Left="57" Canvas.Top="35" Fill="{StaticResource HullBlack}" Opacity="0.56"/>
                                    <Rectangle Width="20" Height="2" Canvas.Left="42" Canvas.Top="51" Fill="{StaticResource HullBlack}" Opacity="0.50"/>
                                    <Rectangle Width="30" Height="3" Canvas.Left="91" Canvas.Top="8" Fill="{StaticResource HullBlack}" Opacity="0.66"/>
                                    <Rectangle Width="18" Height="2" Canvas.Left="105" Canvas.Top="31" Fill="{StaticResource HullBlack}" Opacity="0.58"/>
                                    <Rectangle Width="28" Height="2" Canvas.Left="91" Canvas.Top="49" Fill="{StaticResource HullBlack}" Opacity="0.54"/>
                                </Canvas>
                                <Canvas IsHitTestVisible="False">
                                    <Rectangle x:Name="LogoNoiseCrownA" Width="36" Height="2" Canvas.Left="43" Canvas.Top="-4" Fill="{StaticResource SignalCyan}" Opacity="0"/>
                                    <Rectangle x:Name="LogoNoiseCrownB" Width="12" Height="1" Canvas.Left="72" Canvas.Top="3" Fill="{StaticResource TextPrimary}" Opacity="0"/>
                                    <Rectangle x:Name="LogoNoiseSLeftA" Width="20" Height="1" Canvas.Left="-3" Canvas.Top="13" Fill="{StaticResource TextPrimary}" Opacity="0"/>
                                    <Rectangle x:Name="LogoNoiseSLeftB" Width="9" Height="1" Canvas.Left="13" Canvas.Top="24" Fill="{StaticResource SignalCyan}" Opacity="0"/>
                                    <Rectangle x:Name="LogoNoiseMRightA" Width="16" Height="1" Canvas.Left="99" Canvas.Top="15" Fill="{StaticResource SignalAmber}" Opacity="0"/>
                                    <Rectangle x:Name="LogoNoiseMRightB" Width="16" Height="1" Canvas.Left="121" Canvas.Top="19" Fill="{StaticResource SignalAmber}" Opacity="0"/>
                                    <Rectangle x:Name="LogoNoiseMidA" Width="15" Height="1" Canvas.Left="31" Canvas.Top="31" Fill="{StaticResource SignalCyan}" Opacity="0"/>
                                    <Rectangle x:Name="LogoNoiseMidB" Width="16" Height="1" Canvas.Left="78" Canvas.Top="34" Fill="{StaticResource SignalCyan}" Opacity="0"/>
                                    <Rectangle x:Name="LogoNoiseSBaseA" Width="17" Height="1" Canvas.Left="20" Canvas.Top="51" Fill="{StaticResource TextPrimary}" Opacity="0"/>
                                    <Rectangle x:Name="LogoNoiseMBaseC" Width="18" Height="1" Canvas.Left="121" Canvas.Top="50" Fill="{StaticResource SignalAmber}" Opacity="0"/>
                                    <Rectangle x:Name="LogoNoiseBaseA" Width="38" Height="2" Canvas.Left="42" Canvas.Top="65" Fill="{StaticResource SignalCyan}" Opacity="0"/>
                                    <Rectangle x:Name="LogoNoiseBaseB" Width="14" Height="1" Canvas.Left="53" Canvas.Top="58" Fill="{StaticResource TextPrimary}" Opacity="0"/>
                                    <Canvas.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="LogoNoiseCrownA" Storyboard.TargetProperty="Opacity" From="0" To="0.52" Duration="0:0:1.32" BeginTime="0:0:0.00" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoNoiseCrownB" Storyboard.TargetProperty="Opacity" From="0" To="0.32" Duration="0:0:1.05" BeginTime="0:0:0.39" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoNoiseSLeftA" Storyboard.TargetProperty="Opacity" From="0" To="0.28" Duration="0:0:1.64" BeginTime="0:0:0.62" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoNoiseSLeftB" Storyboard.TargetProperty="Opacity" From="0" To="0.24" Duration="0:0:0.92" BeginTime="0:0:0.84" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoNoiseMRightA" Storyboard.TargetProperty="Opacity" From="0" To="0.42" Duration="0:0:1.18" BeginTime="0:0:0.25" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoNoiseMRightB" Storyboard.TargetProperty="Opacity" From="0" To="0.34" Duration="0:0:1.86" BeginTime="0:0:0.93" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoNoiseMidA" Storyboard.TargetProperty="Opacity" From="0" To="0.34" Duration="0:0:1.48" BeginTime="0:0:0.12" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoNoiseMidB" Storyboard.TargetProperty="Opacity" From="0" To="0.36" Duration="0:0:1.12" BeginTime="0:0:1.08" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoNoiseSBaseA" Storyboard.TargetProperty="Opacity" From="0" To="0.24" Duration="0:0:1.22" BeginTime="0:0:0.71" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoNoiseMBaseC" Storyboard.TargetProperty="Opacity" From="0" To="0.32" Duration="0:0:1.58" BeginTime="0:0:0.46" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoNoiseBaseA" Storyboard.TargetProperty="Opacity" From="0" To="0.48" Duration="0:0:1.44" BeginTime="0:0:0.67" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoNoiseBaseB" Storyboard.TargetProperty="Opacity" From="0" To="0.28" Duration="0:0:1.02" BeginTime="0:0:0.18" AutoReverse="True" RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Canvas.Triggers>
                                </Canvas>
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,2,0,0">
                                <TextBlock x:Name="BrandRelayText"
                                           Foreground="{StaticResource SignalAmber}"
                                           FontSize="10.5"
                                           FontWeight="Bold"
                                           LineHeight="10"
                                           LineStackingStrategy="BlockLineHeight"/>
                                <TextBlock x:Name="TitleText"
                                           Margin="0,-2,0,0"
                                           FontSize="19.5"
                                           FontWeight="Bold"
                                           LineHeight="21"
                                           LineStackingStrategy="BlockLineHeight"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="HeaderVersionText"
                                   VerticalAlignment="Center"
                                   Margin="0,0,18,0"
                                   Foreground="{StaticResource SignalCyan}"
                                   FontSize="15"
                                   FontWeight="SemiBold"/>
                        <Button x:Name="MinimizeButton" Content="—" Width="38" MinHeight="30" Padding="0" Margin="8,0,6,0" Click="MinimizeWindow"/>
                        <Button x:Name="CloseButton" Content="×" Width="38" MinHeight="30" Padding="0" Click="CloseWindow"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="330"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Padding="0" Margin="0,0,10,0">
                    <Grid ClipToBounds="True">
                        <Image x:Name="MainDisplayImage" Stretch="UniformToFill" Opacity="0"/>
                        <Rectangle Fill="Transparent"/>
                        <Rectangle Opacity="0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#66070B0F" Offset="0"/>
                                    <GradientStop Color="#36070B0F" Offset="0.50"/>
                                    <GradientStop Color="#14102831" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="72"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" BorderBrush="#2F5360" BorderThickness="0,0,0,1" Padding="18,9,18,10">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock x:Name="ScreenTitleText" AutomationProperties.AutomationId="ScreenTitleText" FontSize="23" FontWeight="Bold"/>
                                        <TextBlock x:Name="ScreenSubtitleText" Margin="0,3,0,0" Foreground="{StaticResource TextSecondary}" FontSize="12" LineHeight="16"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" Margin="18,12,18,18">
                                <ScrollViewer x:Name="OverviewPanel" VerticalScrollBarVisibility="Auto">
                                    <Border BorderBrush="Transparent" BorderThickness="0" Padding="18" Background="Transparent">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="320"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
                                                    <StackPanel>
                                                        <TextBlock x:Name="LivePathLabel" Foreground="{StaticResource SignalAmber}" FontSize="13.5" FontWeight="Bold"/>
                                                        <Grid Margin="0,10,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="116"/>
                                                                <ColumnDefinition Width="150"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox x:Name="LivePathBox" AutomationProperties.AutomationId="LivePathBox" Grid.Column="0" MinHeight="46" VerticalContentAlignment="Center" Padding="10,0"/>
                                                            <Button x:Name="BrowseButton" AutomationProperties.AutomationId="BrowseButton" Grid.Column="1" Style="{StaticResource CommandButton}" Margin="10,0,0,0" Click="BrowseLivePath"/>
                                                            <Button x:Name="CheckPathButton" AutomationProperties.AutomationId="CheckPathButton" Grid.Column="2" Style="{StaticResource CommandButton}" Margin="10,0,0,0" Click="CheckPath"/>
                                                        </Grid>
                                                        <TextBlock x:Name="LiveStatusText" Visibility="Collapsed"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
                                                    <StackPanel>
                                                        <TextBlock Text="МОДУЛИ" Foreground="{StaticResource SignalCyan}" FontWeight="Bold"/>
                                                        <TextBlock x:Name="ModulesStatusText" Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>

                                                 <Border Style="{StaticResource PanelBorder}">
                                                     <StackPanel>
                                                         <TextBlock Text="ОБНОВЛЕНИЯ" Foreground="{StaticResource SignalCyan}" FontWeight="Bold"/>
                                                        <TextBlock x:Name="UpdateStatusText" Margin="0,5,0,0" Foreground="{StaticResource SignalAmber}" FontWeight="Bold" TextWrapping="Wrap"/>
                                                        <TextBlock x:Name="UpdatesScaffoldText" Margin="0,4,0,0" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                                                        <UniformGrid Columns="2" Margin="0,8,0,0">
                                                            <Button x:Name="CheckUpdatesButton" AutomationProperties.AutomationId="CheckUpdatesButton" Style="{StaticResource CommandButton}" MinHeight="32" Margin="0,0,8,0" Click="CheckUpdates"/>
                                                            <Button x:Name="InstallUpdateButton" AutomationProperties.AutomationId="InstallUpdateButton" Style="{StaticResource CommandButton}" MinHeight="32" IsEnabled="False" Click="UpdateLauncher"/>
                                                        </UniformGrid>
                                                     </StackPanel>
                                                 </Border>
                                            </StackPanel>

                                            <Border Grid.Column="1" BorderBrush="Transparent" BorderThickness="0" Background="Transparent" Padding="0" Margin="9,0,9,0">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0">
                                                    <Grid Width="344" Height="318" HorizontalAlignment="Center" ClipToBounds="False" IsHitTestVisible="False" Margin="-12,0,0,0">
                                                        <Grid.OpacityMask>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                                                <GradientStop Color="#FFFFFFFF" Offset="0.64"/>
                                                                <GradientStop Color="#33FFFFFF" Offset="0.88"/>
                                                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Grid.OpacityMask>

                                                        <Image x:Name="HologramImage"
                                                               Margin="14,0,0,0"
                                                               Stretch="Uniform"
                                                               Opacity="0.72"
                                                               RenderTransformOrigin="0.5,0.5">
                                                            <Image.RenderTransform>
                                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                            </Image.RenderTransform>
                                                            <Image.Effect>
                                                                <DropShadowEffect BlurRadius="13" ShadowDepth="0" Opacity="0.52" Color="#66E8FF"/>
                                                            </Image.Effect>
                                                        </Image>

                                                        <Image x:Name="HologramGhostLeft"
                                                               Margin="14,0,0,0"
                                                               Stretch="Uniform"
                                                               Opacity="0.06"
                                                               RenderTransformOrigin="0.5,0.5">
                                                            <Image.RenderTransform>
                                                                <TransformGroup>
                                                                    <TranslateTransform x:Name="HologramGhostLeftJitter" X="-3" Y="0"/>
                                                                </TransformGroup>
                                                            </Image.RenderTransform>
                                                        </Image>

                                                        <Image x:Name="HologramGhostRight"
                                                               Margin="14,0,0,0"
                                                               Stretch="Uniform"
                                                               Opacity="0.045"
                                                               RenderTransformOrigin="0.5,0.5">
                                                            <Image.RenderTransform>
                                                                <TransformGroup>
                                                                    <TranslateTransform x:Name="HologramGhostRightJitter" X="3" Y="0"/>
                                                                </TransformGroup>
                                                            </Image.RenderTransform>
                                                        </Image>

                                                        <Canvas ClipToBounds="False">
                                                            <Canvas x:Name="HologramGlitchLayerA" Opacity="0.26">
                                                                <Canvas.RenderTransform>
                                                                    <TranslateTransform x:Name="HologramGlitchLayerAJitter" X="0" Y="0"/>
                                                                </Canvas.RenderTransform>
                                                                <Rectangle Width="32" Height="1.4" Canvas.Left="78" Canvas.Top="80" Fill="{StaticResource SignalCyan}" Opacity="0.58"/>
                                                                <Rectangle Width="18" Height="1" Canvas.Left="132" Canvas.Top="96" Fill="{StaticResource TextPrimary}" Opacity="0.34"/>
                                                                <Rectangle Width="44" Height="1.2" Canvas.Left="212" Canvas.Top="116" Fill="{StaticResource SignalCyan}" Opacity="0.42"/>
                                                                <Rectangle Width="24" Height="1" Canvas.Left="92" Canvas.Top="148" Fill="{StaticResource SignalAmber}" Opacity="0.30"/>
                                                                <Rectangle Width="36" Height="1.5" Canvas.Left="246" Canvas.Top="172" Fill="{StaticResource TextPrimary}" Opacity="0.26"/>
                                                                <Rectangle Width="28" Height="1.1" Canvas.Left="154" Canvas.Top="210" Fill="{StaticResource SignalCyan}" Opacity="0.36"/>
                                                                <Rectangle Width="52" Height="1.2" Canvas.Left="72" Canvas.Top="238" Fill="{StaticResource SignalAmber}" Opacity="0.22"/>
                                                            </Canvas>
                                                            <Canvas x:Name="HologramGlitchLayerB" Opacity="0.18">
                                                                <Canvas.RenderTransform>
                                                                    <TranslateTransform x:Name="HologramGlitchLayerBJitter" X="0" Y="0"/>
                                                                </Canvas.RenderTransform>
                                                                <Rectangle Width="20" Height="1" Canvas.Left="186" Canvas.Top="72" Fill="{StaticResource SignalAmber}" Opacity="0.34"/>
                                                                <Rectangle Width="38" Height="1.3" Canvas.Left="104" Canvas.Top="120" Fill="{StaticResource SignalCyan}" Opacity="0.38"/>
                                                                <Rectangle Width="16" Height="1" Canvas.Left="278" Canvas.Top="139" Fill="{StaticResource TextPrimary}" Opacity="0.28"/>
                                                                <Rectangle Width="30" Height="1.1" Canvas.Left="140" Canvas.Top="183" Fill="{StaticResource SignalAmber}" Opacity="0.26"/>
                                                                <Rectangle Width="46" Height="1.2" Canvas.Left="220" Canvas.Top="225" Fill="{StaticResource SignalCyan}" Opacity="0.30"/>
                                                                <Rectangle Width="22" Height="1" Canvas.Left="116" Canvas.Top="258" Fill="{StaticResource TextPrimary}" Opacity="0.22"/>
                                                            </Canvas>
                                                        </Canvas>

                                                        <Grid.Triggers>
                                                            <EventTrigger RoutedEvent="Loaded">
                                                                <BeginStoryboard>
                                                                    <Storyboard RepeatBehavior="Forever">
                                                                        <DoubleAnimation Storyboard.TargetName="HologramImage"
                                                                                         Storyboard.TargetProperty="Opacity"
                                                                                         From="0.66"
                                                                                         To="0.78"
                                                                                         Duration="0:0:1.22"
                                                                                         AutoReverse="True"/>
                                                                        <DoubleAnimation Storyboard.TargetName="HologramGhostLeftJitter"
                                                                                         Storyboard.TargetProperty="X"
                                                                                         From="-5"
                                                                                         To="1"
                                                                                         Duration="0:0:0.38"
                                                                                         AutoReverse="True"/>
                                                                        <DoubleAnimation Storyboard.TargetName="HologramGhostRightJitter"
                                                                                         Storyboard.TargetProperty="X"
                                                                                         From="5"
                                                                                         To="-1"
                                                                                         Duration="0:0:0.46"
                                                                                         AutoReverse="True"/>
                                                                        <DoubleAnimation Storyboard.TargetName="HologramGlitchLayerA"
                                                                                         Storyboard.TargetProperty="Opacity"
                                                                                         From="0.08"
                                                                                         To="0.44"
                                                                                         Duration="0:0:0.78"
                                                                                         AutoReverse="True"/>
                                                                        <DoubleAnimation Storyboard.TargetName="HologramGlitchLayerAJitter"
                                                                                         Storyboard.TargetProperty="X"
                                                                                         From="-4"
                                                                                         To="7"
                                                                                         Duration="0:0:0.78"
                                                                                         AutoReverse="True"/>
                                                                        <DoubleAnimation Storyboard.TargetName="HologramGlitchLayerB"
                                                                                         Storyboard.TargetProperty="Opacity"
                                                                                         From="0"
                                                                                         To="0.32"
                                                                                         BeginTime="0:0:0.24"
                                                                                         Duration="0:0:0.94"
                                                                                         AutoReverse="True"/>
                                                                        <DoubleAnimation Storyboard.TargetName="HologramGlitchLayerBJitter"
                                                                                         Storyboard.TargetProperty="X"
                                                                                         From="6"
                                                                                         To="-5"
                                                                                         BeginTime="0:0:0.24"
                                                                                         Duration="0:0:0.94"
                                                                                         AutoReverse="True"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                        </Grid.Triggers>
                                                    </Grid>

                                                    <Grid x:Name="SignatureFrame"
                                                          HorizontalAlignment="Center"
                                                          Margin="10,10,0,0"
                                                          RenderTransformOrigin="0.5,0.5">
                                                        <Grid.RenderTransform>
                                                            <TranslateTransform x:Name="SignatureTextJitter" X="0" Y="0"/>
                                                        </Grid.RenderTransform>
                                                        <Grid.Effect>
                                                            <DropShadowEffect x:Name="SignatureTextGlow"
                                                                              BlurRadius="6"
                                                                              ShadowDepth="0"
                                                                              Opacity="0.26"
                                                                              Color="#66E8FF"/>
                                                        </Grid.Effect>
                                                        <TextBlock x:Name="SignatureButton"
                                                                   AutomationProperties.AutomationId="SignatureButton"
                                                                   AutomationProperties.Name="Johnnie на связи"
                                                                   FontSize="20"
                                                                   FontWeight="Normal"
                                                                   TextOptions.TextFormattingMode="Display"
                                                                   TextOptions.TextRenderingMode="ClearType">
                                                            <InlineUIContainer BaselineAlignment="Center">
                                                                <Grid Width="26" Height="22" Margin="0,0,3,-3">
                                                                    <Viewbox Stretch="Uniform">
                                                                        <Grid Width="24" Height="24">
                                                                            <Path Fill="#5865F2"
