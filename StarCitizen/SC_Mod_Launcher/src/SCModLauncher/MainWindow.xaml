<Window x:Class="SCModLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="SC Mod Launcher"
        Icon="Assets/scm-launcher.ico"
        AutomationProperties.AutomationId="RootWindow"
        Width="1280"
        Height="820"
        MinWidth="1120"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource HullBlack}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Image x:Name="BackdropImage" Stretch="UniformToFill" Opacity="0.84"/>
        <Rectangle Fill="#5C070B0F"/>
        <Rectangle>
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.72,0.34" GradientOrigin="0.72,0.34" RadiusX="0.86" RadiusY="0.92">
                    <GradientStop Color="#16288999" Offset="0"/>
                    <GradientStop Color="#38070B0F" Offset="0.48"/>
                    <GradientStop Color="#8E070B0F" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Border Background="{StaticResource GlassPanel}" IsHitTestVisible="False"/>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="104"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="112"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PanelBorder}" Padding="16" Margin="0" MouseLeftButtonDown="HeaderMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Height="66" Margin="0,-4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Width="144" Height="66" ClipToBounds="False" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="LogoRootScale" ScaleX="1" ScaleY="1"/>
                                        <TranslateTransform x:Name="LogoRootShift" X="0" Y="0"/>
                                    </TransformGroup>
                                </Grid.RenderTransform>
                                <Grid.Effect>
                                    <DropShadowEffect x:Name="LogoGlow"
                                                      BlurRadius="9"
                                                      ShadowDepth="0"
                                                      Opacity="0.26"
                                                      Color="#66E8FF"/>
                                </Grid.Effect>
                                <Grid.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoRootScale" Storyboard.TargetProperty="ScaleX">
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="1"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:2.40" Value="1"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:2.62" Value="1.012"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:2.88" Value="0.998"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:3.14" Value="1.006"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:5.20" Value="1"/>
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoRootScale" Storyboard.TargetProperty="ScaleY">
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="1"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:2.64" Value="1"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:2.86" Value="0.996"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:3.10" Value="1.002"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:5.20" Value="1"/>
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoRootShift" Storyboard.TargetProperty="X">
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:2.52" Value="0"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:2.66" Value="-0.7"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:2.80" Value="0.5"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:2.98" Value="-0.2"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:3.14" Value="0"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:5.20" Value="0"/>
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoRootShift" Storyboard.TargetProperty="Y">
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:2.82" Value="0"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:2.94" Value="-0.3"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:3.08" Value="0.2"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:3.24" Value="0"/>
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:5.20" Value="0"/>
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimation Storyboard.TargetName="LogoGlow"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 From="0.16"
                                                                 To="0.34"
                                                                 Duration="0:0:2.60"
                                                                 AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Grid.Triggers>

                                <Canvas x:Name="LogoCyanGhost" IsHitTestVisible="False" Opacity="0.08">
                                    <Canvas.RenderTransform>
                                        <TranslateTransform x:Name="LogoCyanGhostShift" X="-2.2" Y="0"/>
                                    </Canvas.RenderTransform>
                                    <TextBlock Text="S" Canvas.Left="0" Canvas.Top="-6" Foreground="{StaticResource SignalCyan}" FontFamily="Segoe UI Black" FontSize="52" FontWeight="Black"/>
                                    <TextBlock Text="C" Canvas.Left="36" Canvas.Top="-6" Foreground="{StaticResource SignalCyan}" FontFamily="Segoe UI Black" FontSize="52" FontWeight="Black"/>
                                    <TextBlock Text="M" Canvas.Left="74" Canvas.Top="-6" Foreground="{StaticResource SignalCyan}" FontFamily="Segoe UI Black" FontSize="52" FontWeight="Black"/>
                                    <Canvas.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoCyanGhost" Storyboard.TargetProperty="Opacity">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="0.05"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.50" Value="0.05"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.68" Value="0.26"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.90" Value="0.09"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:5.20" Value="0.05"/>
                                                    </DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoCyanGhostShift" Storyboard.TargetProperty="X">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="-1.2"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.56" Value="-1.2"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.74" Value="-3.2"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.98" Value="-1.3"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:5.20" Value="-1.2"/>
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Canvas.Triggers>
                                </Canvas>

                                <Canvas x:Name="LogoAmberGhost" IsHitTestVisible="False" Opacity="0.05">
                                    <Canvas.RenderTransform>
                                        <TranslateTransform x:Name="LogoAmberGhostShift" X="1.5" Y="0"/>
                                    </Canvas.RenderTransform>
                                    <TextBlock Text="S" Canvas.Left="0" Canvas.Top="-6" Foreground="{StaticResource SignalAmber}" FontFamily="Segoe UI Black" FontSize="52" FontWeight="Black"/>
                                    <TextBlock Text="C" Canvas.Left="36" Canvas.Top="-6" Foreground="{StaticResource SignalAmber}" FontFamily="Segoe UI Black" FontSize="52" FontWeight="Black"/>
                                    <TextBlock Text="M" Canvas.Left="74" Canvas.Top="-6" Foreground="{StaticResource SignalAmber}" FontFamily="Segoe UI Black" FontSize="52" FontWeight="Black"/>
                                    <Canvas.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.42">
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoAmberGhost" Storyboard.TargetProperty="Opacity">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="0.04"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.34" Value="0.04"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.56" Value="0.17"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.78" Value="0.07"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:5.00" Value="0.04"/>
                                                    </DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoAmberGhostShift" Storyboard.TargetProperty="X">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="1.3"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.42" Value="1.3"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.62" Value="2.7"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.84" Value="1.2"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:5.00" Value="1.3"/>
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Canvas.Triggers>
                                </Canvas>

                                <Canvas>
                                    <TextBlock x:Name="LogoLetterS" Text="S" Canvas.Left="0" Canvas.Top="-6" Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI Black" FontSize="52" FontWeight="Black">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform x:Name="LogoLetterSShift" X="0" Y="0"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                    <TextBlock x:Name="LogoLetterC" Text="C" Canvas.Left="36" Canvas.Top="-6" Foreground="{StaticResource SignalCyan}" FontFamily="Segoe UI Black" FontSize="52" FontWeight="Black">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform x:Name="LogoLetterCShift" X="0" Y="0"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                    <TextBlock x:Name="LogoLetterM" Text="M" Canvas.Left="74" Canvas.Top="-6" Foreground="{StaticResource SignalAmber}" FontFamily="Segoe UI Black" FontSize="52" FontWeight="Black">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform x:Name="LogoLetterMShift" X="0" Y="0"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                    <Canvas.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoLetterSShift" Storyboard.TargetProperty="X">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.52" Value="0"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.70" Value="-0.8"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.88" Value="0.2"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:3.10" Value="0"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:5.20" Value="0"/>
                                                    </DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoLetterCShift" Storyboard.TargetProperty="X">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.76" Value="0"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:2.94" Value="0.7"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:3.14" Value="-0.2"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:3.34" Value="0"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:5.20" Value="0"/>
                                                    </DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoLetterMShift" Storyboard.TargetProperty="X">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:3.02" Value="0"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:3.20" Value="-0.6"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:3.40" Value="0.3"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:3.60" Value="0"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:5.20" Value="0"/>
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Canvas.Triggers>
                                </Canvas>

                                <Canvas IsHitTestVisible="False">
                                    <Rectangle Width="17" Height="2" Canvas.Left="3" Canvas.Top="7" Fill="{StaticResource HullBlack}" Opacity="0.72"/>
                                    <Rectangle Width="29" Height="2" Canvas.Left="9" Canvas.Top="27" Fill="{StaticResource HullBlack}" Opacity="0.56"/>
                                    <Rectangle Width="12" Height="2" Canvas.Left="28" Canvas.Top="46" Fill="{StaticResource HullBlack}" Opacity="0.62"/>
                                    <Rectangle Width="20" Height="2" Canvas.Left="39" Canvas.Top="10" Fill="{StaticResource HullBlack}" Opacity="0.68"/>
                                    <Rectangle Width="14" Height="2" Canvas.Left="53" Canvas.Top="31" Fill="{StaticResource HullBlack}" Opacity="0.55"/>
                                    <Rectangle Width="24" Height="2" Canvas.Left="40" Canvas.Top="49" Fill="{StaticResource HullBlack}" Opacity="0.50"/>
                                    <Rectangle Width="28" Height="2" Canvas.Left="80" Canvas.Top="6" Fill="{StaticResource HullBlack}" Opacity="0.66"/>
                                    <Rectangle Width="16" Height="2" Canvas.Left="95" Canvas.Top="29" Fill="{StaticResource HullBlack}" Opacity="0.58"/>
                                    <Rectangle Width="30" Height="2" Canvas.Left="84" Canvas.Top="48" Fill="{StaticResource HullBlack}" Opacity="0.54"/>
                                    <Rectangle Width="8" Height="1" Canvas.Left="66" Canvas.Top="17" Fill="{StaticResource HullBlack}" Opacity="0.58"/>
                                    <Rectangle Width="10" Height="1" Canvas.Left="116" Canvas.Top="36" Fill="{StaticResource HullBlack}" Opacity="0.60"/>
                                </Canvas>

                                <Canvas IsHitTestVisible="False" ClipToBounds="False">
                                    <Rectangle x:Name="LogoTearWideA" Width="58" Height="4" Canvas.Left="-7" Canvas.Top="13" Fill="#3066E8FF" Opacity="0"/>
                                    <Rectangle x:Name="LogoTearWideB" Width="40" Height="3" Canvas.Left="37" Canvas.Top="35" Fill="#24EAF9FF" Opacity="0"/>
                                    <Rectangle x:Name="LogoTearWideC" Width="47" Height="4" Canvas.Left="77" Canvas.Top="23" Fill="#24FFB84A" Opacity="0"/>
                                    <Rectangle x:Name="LogoRipMidM" Width="40" Height="2" Canvas.Left="81" Canvas.Top="41" Fill="{StaticResource SignalAmber}" Opacity="0"/>
                                    <Canvas.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="LogoTearWideA" Storyboard.TargetProperty="Opacity" From="0" To="0.14" Duration="0:0:0.40" BeginTime="0:0:2.52" AutoReverse="True"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoTearWideB" Storyboard.TargetProperty="Opacity" From="0" To="0.11" Duration="0:0:0.44" BeginTime="0:0:2.92" AutoReverse="True"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoTearWideC" Storyboard.TargetProperty="Opacity" From="0" To="0.10" Duration="0:0:0.38" BeginTime="0:0:3.32" AutoReverse="True"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoRipMidM" Storyboard.TargetProperty="Opacity" From="0" To="0.20" Duration="0:0:0.40" BeginTime="0:0:3.08" AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Canvas.Triggers>
                                </Canvas>
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,2,0,0">
                                <TextBlock x:Name="BrandRelayText"
                                           Foreground="{StaticResource SignalAmber}"
                                           FontSize="10.5"
                                           FontWeight="Bold"
                                           LineHeight="10"
                                           LineStackingStrategy="BlockLineHeight"/>
                                <TextBlock x:Name="TitleText"
                                           Margin="0,-2,0,0"
                                           FontSize="19.5"
                                           FontWeight="Bold"
                                           LineHeight="21"
                                           LineStackingStrategy="BlockLineHeight"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="HeaderVersionText"
                                   VerticalAlignment="Center"
                                   Margin="0,0,18,0"
                                   Foreground="{StaticResource SignalCyan}"
                                   FontSize="15"
                                   FontWeight="SemiBold"/>
                        <Button x:Name="ResetWindowSizeButton"
                                AutomationProperties.AutomationId="ResetWindowSizeButton"
                                AutomationProperties.Name="Вернуть размер окна"
                                Content="□"
                                Width="38"
                                MinHeight="30"
                                Padding="0"
                                Margin="8,0,6,0"
                                ToolTip="Вернуть размер окна"
                                Click="ResetWindowSize"/>
                        <Button x:Name="MinimizeButton" Content="—" Width="38" MinHeight="30" Padding="0" Margin="0,0,6,0" Click="MinimizeWindow"/>
                        <Button x:Name="CloseButton" Content="×" Width="38" MinHeight="30" Padding="0" Click="CloseWindow"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="330"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Padding="0" Margin="0,0,10,0">
                    <Grid ClipToBounds="True">
                        <Image x:Name="MainDisplayImage" Stretch="UniformToFill" Opacity="0"/>
                        <Rectangle Fill="Transparent"/>
                        <Rectangle Opacity="0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#66070B0F" Offset="0"/>
                                    <GradientStop Color="#36070B0F" Offset="0.50"/>
                                    <GradientStop Color="#14102831" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="72"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" BorderBrush="#2F5360" BorderThickness="0,0,0,1" Padding="18,9,18,10">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock x:Name="ScreenTitleText" AutomationProperties.AutomationId="ScreenTitleText" FontSize="23" FontWeight="Bold"/>
                                        <TextBlock x:Name="ScreenSubtitleText" Margin="0,3,0,0" Foreground="{StaticResource TextSecondary}" FontSize="12" LineHeight="16"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" Margin="18,12,18,18">
                                <ScrollViewer x:Name="OverviewPanel" VerticalScrollBarVisibility="Auto">
                                    <Border BorderBrush="Transparent" BorderThickness="0" Padding="18" Background="Transparent">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="320"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
                                                    <StackPanel>
                                                        <TextBlock x:Name="LivePathLabel" Foreground="{StaticResource SignalAmber}" FontSize="13.5" FontWeight="Bold"/>
                                                        <Grid Margin="0,10,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="116"/>
                                                                <ColumnDefinition Width="150"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox x:Name="LivePathBox" AutomationProperties.AutomationId="LivePathBox" Grid.Column="0" Style="{StaticResource LaunchPathTextBox}" VerticalContentAlignment="Center"/>
                                                            <Button x:Name="BrowseButton" AutomationProperties.AutomationId="BrowseButton" Grid.Column="1" Style="{StaticResource LaunchCommandButton}" MinHeight="42" Margin="10,0,0,0" Click="BrowseLivePath"/>
                                                            <Button x:Name="CheckPathButton" AutomationProperties.AutomationId="CheckPathButton" Grid.Column="2" Style="{StaticResource LaunchCommandButton}" MinHeight="42" Margin="10,0,0,0" Click="CheckPath"/>
                                                        </Grid>
                                                        <TextBlock x:Name="LiveStatusText" Visibility="Collapsed"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
                                                    <StackPanel>
                                                        <TextBlock Text="МОДУЛИ" Foreground="{StaticResource SignalCyan}" FontWeight="Bold"/>
                                                        <TextBlock x:Name="ModulesStatusText" Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Style="{StaticResource PanelBorder}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Grid MinHeight="110" Margin="0,0,8,0">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="*"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <TextBlock Text="ЛАУНЧЕР" Foreground="{StaticResource SignalCyan}" FontWeight="Bold"/>
                                                                <StackPanel Grid.Row="1" Margin="0,5,0,0">
                                                                    <TextBlock x:Name="UpdateStatusText" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" FontSize="13" LineHeight="17" TextWrapping="Wrap"/>
                                                                    <TextBlock x:Name="UpdatesScaffoldText" Margin="0,4,0,0" Foreground="{StaticResource TextSecondary}" FontSize="13" LineHeight="17" TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                                <Button x:Name="InstallUpdateButton" AutomationProperties.AutomationId="InstallUpdateButton" Grid.Row="2" Style="{StaticResource LaunchCommandButton}" MinHeight="42" Width="112" HorizontalAlignment="Left" IsEnabled="False" Click="UpdateLauncher"/>
                                                            </Grid>

                                                            <Grid Grid.Column="1" MinHeight="110" Margin="8,0,0,0">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="*"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <TextBlock Text="РУСИФИКАТОР" Foreground="{StaticResource SignalCyan}" FontWeight="Bold"/>
                                                                <StackPanel Grid.Row="1" Margin="0,5,0,0">
                                                                    <TextBlock x:Name="OverviewLocalizationVersionText" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" FontSize="13" LineHeight="17" TextWrapping="Wrap"/>
                                                                    <TextBlock x:Name="OverviewLocalizationStatusText" Margin="0,4,0,0" Foreground="{StaticResource TextSecondary}" FontSize="13" LineHeight="17" TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                                <Button x:Name="OverviewUpdateLocalizationButton" AutomationProperties.AutomationId="OverviewUpdateLocalizationButton" Grid.Row="2" Style="{StaticResource LaunchCommandButton}" MinHeight="42" Width="112" HorizontalAlignment="Left" IsEnabled="False" Click="UpdateLocalization"/>
                                                            </Grid>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>

                                            <Border Grid.Column="1" BorderBrush="Transparent" BorderThickness="0" Background="Transparent" Padding="0" Margin="9,0,9,0">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0">
                                                    <Grid Width="344" Height="318" HorizontalAlignment="Center" ClipToBounds="False" IsHitTestVisible="False" Margin="-12,0,0,0">
                                                        <Grid.OpacityMask>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                                                <GradientStop Color="#FFFFFFFF" Offset="0.64"/>
                                                                <GradientStop Color="#33FFFFFF" Offset="0.88"/>
                                                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Grid.OpacityMask>

                                                        <Image x:Name="HologramImage"
                                                               Margin="14,0,0,0"
