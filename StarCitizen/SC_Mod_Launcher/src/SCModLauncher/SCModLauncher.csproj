<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>SCModLauncher</AssemblyName>
    <RootNamespace>SCModLauncher</RootNamespace>
    <ApplicationIcon>Assets\scm-launcher.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <Resource Include="Assets\scm-launcher.ico" />
  </ItemGroup>
</Project>
